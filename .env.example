# PocketStream Configuration
# Copy this file to .env and customize

# Public base URL used for generating RSS feed links
POCKETSTREAM_BASE_URL=http://192.168.68.110:8080

# API key for the /api/enqueue endpoint (used by the Android app)
POCKETSTREAM_API_KEY=change-me-to-something-random

# Basic auth credentials for RSS feed and audio file access
POCKETSTREAM_BASIC_USER=pocket
POCKETSTREAM_BASIC_PASS=change-me-to-something-random

# Maximum storage for downloaded audio files (GB)
POCKETSTREAM_MAX_STORAGE_GB=50

# Maximum number of items in the download queue
POCKETSTREAM_MAX_QUEUE_SIZE=50

# Data directory for database, audio files, and RSS feed
POCKETSTREAM_DATA_DIR=/data
